# Copy to .env.local (local dev) or paste into Vercel → Settings → Environment Variables.

# The *.myshopify.com domain — NOT nordicengros.com
SHOPIFY_STORE_DOMAIN=nordic-engros.myshopify.com

# Admin API access token (shpat_...) from the custom app.
# Required scopes: read_products, write_draft_orders
SHOPIFY_ADMIN_TOKEN=

# Leave as-is unless you have a reason to change it.
SHOPIFY_API_VERSION=2025-01

# Tag applied to every kiosk order, so you can filter them in Shopify admin.
KIOSK_ORDER_TAG=kiosk
